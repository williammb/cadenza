error-app-not-running = The Cadenza app is not running. Open the app and try again.
error-bad-token = CLI token invalid or missing. Try revoking from the tray menu and retrying.
error-protocol-mismatch = Protocol version mismatch ({ $hint }).
error-task-not-found = Task not found: { $task_id }
error-task-busy = Task is in use by another operation — try again shortly.
