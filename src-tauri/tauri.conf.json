{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cadenza",
  "version": "0.1.2",
  "identifier": "com.cadenza.desktop",
  "build": {
    "frontendDist": "../ui",
    "beforeBuildCommand": "cargo build --release -p cadenza-cli"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Cadenza",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../target/release/cadenza-cli.exe": "cadenza-cli.exe"
    },
    "windows": {
      "nsis": {
        "installerHooks": "./installer-hooks.nsh"
      }
    },
    "category": "Productivity",
    "shortDescription": "Cadenza — AI agent task manager",
    "longDescription": "Cadenza is a desktop tray app that lets AI coding agents (Claude Code, Codex) drive a local task board over a CLI."
  }
}
